# Copy this file to .env and adjust values.

# Path to the GGUF file *inside the container* (host dir ./models is mounted at /models).
# For split GGUF shards, point to the first part: *-00001-of-0000N.gguf
MODEL_PATH=/models/qwen2.5-coder-32b-q5_k_m.gguf

# Host directory with GGUF files (mounted read-only into the container).
MODEL_HOST_DIR=./models

# Name exposed through the OpenAI API (the "model" field clients send).
MODEL_ALIAS=qwen2.5-coder-32b

# API key for llama-server (--api-key). Must match what VSCode agents send.
API_KEY=local-key

# Optional: pin llama.cpp to a release tag (e.g. b4400) for reproducible builds.
LLAMA_CPP_REF=master
