# Copy this file to .env and fill in values.
#
# HF_TOKEN: optional for public/non-gated models, but recommended to avoid
# Hugging Face download rate limits. Get one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxx

# Model to serve. GPTQ Int8 is the right pick for V100 (Volta, compute 7.0):
# vLLM supports GPTQ on Volta, but NOT AWQ / FP8 / Marlin kernels.
MODEL_ID=Qwen/Qwen2.5-Coder-32B-Instruct-GPTQ-Int8
