# Copy this file to .env and adjust values.

# Optional HF token: not needed for public GGUF repos, but avoids download
# rate limits. Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# GGUF model repo + quantization tag, used as `-hf <REPO>:<QUANT>`.
# Q5_K_M (~23 GB) is the recommended quality/size balance for 2x V100 32GB.
# Use Q4_K_M (~20 GB) for more headroom / a bit more speed.
MODEL_REPO=bartowski/Qwen2.5-Coder-32B-Instruct-GGUF
MODEL_QUANT=Q5_K_M

# Name exposed through the OpenAI API (the "model" field clients send).
MODEL_ALIAS=qwen2.5-coder-32b

# Optional: pin llama.cpp to a release tag (e.g. b4400) for reproducible builds.
LLAMA_CPP_REF=master
